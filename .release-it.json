{
  "git": {
    "commit": true,
    "commitMessage": "chore(release): ${version}",
    "tag": true,
    "tagName": "v${version}",
    "push": true,
    "requireCleanWorkingDir": true,
    "requireBranch": "main"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits",
        "types": [
          {
            "type": "feat",
            "section": "Features"
          },
          {
            "type": "fix",
            "section": "Bug fixes"
          },
          {
            "type": "perf",
            "section": "Performance"
          },
          {
            "type": "refactor",
            "section": "Refactoring"
          },
          {
            "type": "docs",
            "section": "Documentation"
          },
          {
            "type": "build",
            "section": "Build system"
          },
          {
            "type": "ci",
            "section": "Continuous integration"
          },
          {
            "type": "test",
            "section": "Tests"
          },
          {
            "type": "chore",
            "section": "Maintenance",
            "hidden": true
          }
        ]
      },
      "infile": "CHANGELOG.md",
      "header": "# Changelog"
    }
  }
}
