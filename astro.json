{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": [
    "astro/tsconfigs/strict",
    "./strict.json"
  ],
  "compilerOptions": {
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "jsx": "preserve"
  }
}