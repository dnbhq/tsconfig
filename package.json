{
  "name": "@dnbhq/tsconfig",
  "description": "Shared TypeScript configurations for DNBHQ projects.",
  "version": "0.1.4",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/dnbhq/tsconfig"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "11.0.0",
    "@types/node": "25.6.0",
    "release-it": "20.0.1",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "typescript": ">=5.8",
    "@types/node": ">=24"
  },
  "scripts": {
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "test": "node --test"
  },
  "files": [
    "strict.json",
    "cli.json",
    "astro.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=25"
  },
  "exports": {
    "./strict": "./strict.json",
    "./cli": "./cli.json",
    "./astro": "./astro.json",
    "./strict.json": "./strict.json",
    "./cli.json": "./cli.json",
    "./astro.json": "./astro.json"
  },
  "peerDependenciesMeta": {
    "@types/node": {
      "optional": true
    }
  },
  "tsconfig": "./strict.json",
  "type": "module"
}
